# Copy this file to .env.local and fill in your keys.
# NEVER commit .env.local to version control.

# ElevenLabs API key — used by the frontend (dynamic generation fallback)
VITE_ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# ElevenLabs API key — used by the Vercel serverless proxy (api/elevenlabs.js)
# This key is NOT exposed to the browser.
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here
